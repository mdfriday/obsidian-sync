{
	"name": "obsidian-sync",
	"version": "26.7.2",
	"description": "MDFriday Sync — CouchDB-based vault synchronization for Obsidian with end-to-end encryption. Supports Desktop and Mobile.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"tsc-check": "tsc --noEmit -skipLibCheck",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"keywords": [
		"mdfriday",
		"sync",
		"couchdb",
		"obsidian",
		"markdown",
		"encryption"
	],
	"author": "sunwei",
	"license": "Apache-2.0",
	"devDependencies": {
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^22.13.8",
		"@types/pouchdb": "^6.4.2",
		"@types/pouchdb-adapter-http": "^6.1.6",
		"@types/pouchdb-adapter-idb": "^6.1.7",
		"@types/pouchdb-browser": "^6.1.5",
		"@types/pouchdb-core": "^7.0.15",
		"@types/pouchdb-mapreduce": "^6.1.10",
		"@types/pouchdb-replication": "^6.4.7",
		"@types/transform-pouch": "^1.0.6",
		"@vitest/coverage-v8": "^4.1.9",
		"esbuild": "0.25.0",
		"esbuild-plugin-inline-worker": "^0.1.1",
		"events": "^3.3.0",
		"obsidian": "^1.8.7",
		"pouchdb-adapter-http": "^9.0.0",
		"pouchdb-adapter-idb": "^9.0.0",
		"pouchdb-adapter-indexeddb": "^9.0.0",
		"pouchdb-adapter-memory": "^9.0.0",
		"pouchdb-core": "^9.0.0",
		"pouchdb-errors": "^9.0.0",
		"pouchdb-find": "^9.0.0",
		"pouchdb-mapreduce": "^9.0.0",
		"pouchdb-merge": "^9.0.0",
		"pouchdb-replication": "^9.0.0",
		"pouchdb-utils": "^9.0.0",
		"transform-pouch": "^2.0.0",
		"tslib": "^2.8.1",
		"typescript": "5.9.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"diff-match-patch": "^1.0.5",
		"fflate": "^0.8.2",
		"idb": "^8.0.3",
		"minimatch": "^10.2.5",
		"octagonal-wheels": "^0.1.44",
		"xxhash-wasm-102": "npm:xxhash-wasm@^1.0.2"
	}
}
